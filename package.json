{
  "name": "inspire",
  "displayName": "Inspire",
  "version": "0.0.1",
  "description": "A basic Plasmo extension.",
  "author": "Gypsophila <a44949522@outlook.com>",
  "scripts": {
    "dev": "set PARCEL_WORKERS=0&& plasmo dev",
    "build": "set PARCEL_WORKERS=0&& plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/parcel-optimizer-es": "^0.4.2",
    "katex": "^0.16.9",
    "lucide-react": "^1.7.0",
    "openai": "^6.33.0",
    "pdfjs-dist": "^5.6.205",
    "plasmo": "0.90.5",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^8.0.7",
    "rehype-katex": "^6.0.3",
    "remark-gfm": "^3.0.1",
    "remark-math": "^5.1.1",
    "sharp": "^0.34.5",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@types/sql.js": "^1.4.9",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "overrides": {
    "@swc/core": "1.15.24"
  },
  "manifest": {
    "action": {
      "default_title": "打开 Impulse 侧栏"
    },
    "host_permissions": [
      "https://*/*",
      "http://*/*",
      "file://*/*"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "web_accessible_resources": [
      {
        "resources": ["tabs/pdfviewer.html"],
        "matches": ["<all_urls>"]
      }
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval' http://localhost; object-src 'self'"
    },
    "permissions": [
      "sidePanel",
      "scripting",
      "activeTab",
      "storage",
      "clipboardRead",
      "contextMenus"
    ]
  }
}
