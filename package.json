{
  "name": "inspire",
  "displayName": "Inspire",
  "version": "0.0.1",
  "description": "A basic Plasmo extension.",
  "author": "Gypsophila <a44949522@outlook.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "openai": "^6.33.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "action": {
      "default_title": "打开 Impulse 侧栏"
    },
    "host_permissions": [
      "https://*/*",
      "http://*/*",
      "file://*/*"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "permissions": [
      "sidePanel",
      "scripting",
      "activeTab",
      "storage"
    ]
  }
}
